{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Expanded domain with term groups and keywords",
  "type": "object",
  "required": ["domain", "terms"],
  "properties": {
    "domain": {
      "type": "string",
      "pattern": "^@[a-z_]+$"
    },
    "terms": {
      "type": "object",
      "minProperties": 4,
      "maxProperties": 6,
      "additionalProperties": {
        "type": "array",
        "minItems": 7,
        "maxItems": 7,
        "items": {
          "type": "string",
          "pattern": "^[a-z]+$"
        }
      }
    }
  }
}

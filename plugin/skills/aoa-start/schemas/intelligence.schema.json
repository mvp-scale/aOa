{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "24 semantic domains for the codebase",
  "type": "array",
  "minItems": 24,
  "maxItems": 24,
  "items": {
    "type": "object",
    "required": ["name", "description"],
    "properties": {
      "name": {
        "type": "string",
        "pattern": "^@[a-z_]+$",
        "description": "@lowercase domain name"
      },
      "description": {
        "type": "string",
        "minLength": 80,
        "maxLength": 400,
        "description": "2-4 sentences of developer INTENT"
      }
    }
  }
}

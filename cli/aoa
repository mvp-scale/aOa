cmd_bigrams() {
    # aoa bigrams [--recent] [--min N] [--limit N]  - Show bigrams (usage signals)
    local min_count=""
    local limit=50
    local recent=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --recent|-r)
                recent=true
                shift
                ;;
            --min|-m)
                min_count="${2:-6}"
                shift 2
                ;;
            --limit|-n)
                limit="${2:-50}"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    local project_id=$(get_project_id)
    if [ -z "$project_id" ]; then

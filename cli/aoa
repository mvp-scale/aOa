        echo -e "${CYAN}${BOLD}вҡЎ aOa Working Memory${NC} ${DIM}в”Ӯ${NC} ${files} files ${DIM}в”Ӯ${NC} ${GREEN}${ms}ms${NC}"
        echo ""
        echo "$memory"
    fi
}

